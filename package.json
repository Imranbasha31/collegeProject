{
  "name": "approveiq",
  "version": "1.0.0",
  "description": "Digital Leave Approval System for Educational Institutions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:dashboard": "vite --config dashboard/vite.config.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:dashboard\"",
    "build:dashboard": "vite build --config dashboard/vite.config.js",
    "test:smoke": "node scripts/smoke-test.js",
    "seed": "node database/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "mssql": "^10.0.4",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.4"
  }
}
